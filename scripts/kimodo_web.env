# Shared environment for detached Kimodo tmux services.

export KIMODO_SESSION_NAME=kimodo_web
export KIMODO_WORKDIR=/root/Project/Kimodo
export CONDA_SH=/root/miniforge3/etc/profile.d/conda.sh
export KIMODO_CONDA_ENV=kimodo

export KIMODO_MODEL=Kimodo-G1-RP-v1

export SERVER_NAME=0.0.0.0
export SERVER_PORT=7860
export GRADIO_SERVER_NAME=0.0.0.0
export GRADIO_SERVER_PORT=9550
export TEXT_ENCODER_URL=http://127.0.0.1:9550/
export TEXT_ENCODER_DEVICE=auto

export HF_HUB_DISABLE_XET=1
export HF_HUB_OFFLINE=1
export no_proxy=localhost,127.0.0.1,0.0.0.0
export NO_PROXY=localhost,127.0.0.1,0.0.0.0
